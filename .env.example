# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# Nova Act
NOVA_ACT_API_KEY=your_nova_act_api_key

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Production (set when deploying to EC2)
# PRODUCTION_URL=http://your-ec2-ip-or-domain
