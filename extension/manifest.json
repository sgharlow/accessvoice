{
  "manifest_version": 3,
  "name": "AccessVoice",
  "version": "1.0.0",
  "description": "Voice-driven web browsing for accessibility",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open AccessVoice"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
